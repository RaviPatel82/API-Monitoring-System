FROM node:18-alpine

# Set working directory
WORKDIR /app

# Set NODE_ENV to production
ENV NODE_ENV=production

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm ci --omit=dev

# Copy application code
COPY . .

# Create logs directory
RUN mkdir -p logs

# Start the consumer (correct path)
CMD ["npm", "run", "processor"]